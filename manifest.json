{
  "manifest_version": 3,
  "name": "사운드 압축기 (Dynamic Compressor)",
  "version": "1.0",
  "description": "유튜브 및 지정한 웹사이트의 영상 소리를 일정한 음량으로 자동 조절합니다.",
  "permissions": ["storage", "scripting", "tabs", "activeTab"],
  
  "host_permissions": [
    "https://*.youtube.com/*"
  ],
  
  "optional_host_permissions": [
    "<all_urls>"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/48.png"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}